{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": "notify",
  "mcp": {
    "notion": {
      "type": "remote",
      "url": "https://mcp.notion.com/mcp"
    }
  },

  "plugin": [
    "@mohak34/opencode-notifier@0.2.8",
    "cursor-acp@latest",
    "cursor-acp"
  ],

  "provider": {
    "cursor-acp": {
      "name": "Cursor",
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "baseURL": "http://127.0.0.1:32124/v1"
      },
      "models": {
        "auto": {
          "name": "Auto",
          "cost": {
            "input": 1.25,
            "output": 6,
            "cache_read": 0.25,
            "cache_write": 1.25
          }
        },
        "composer-1.5": {
          "name": "Composer 1.5",
          "cost": {
            "input": 3.5,
            "output": 17.5,
            "cache_read": 0.35,
            "cache_write": 3.5
          }
        },
        "composer-1": {
          "name": "Composer 1"
        },
        "opus-4.6-thinking": {
          "name": "Claude 4.6 Opus (Thinking)"
        },
        "opus-4.6": {
          "name": "Claude 4.6 Opus"
        },
        "sonnet-4.6": {
          "name": "Claude 4.6 Sonnet"
        },
        "sonnet-4.6-thinking": {
          "name": "Claude 4.6 Sonnet (Thinking)"
        },
        "opus-4.5": {
          "name": "Claude 4.5 Opus"
        },
        "opus-4.5-thinking": {
          "name": "Claude 4.5 Opus (Thinking)"
        },
        "sonnet-4.5": {
          "name": "Claude 4.5 Sonnet"
        },
        "sonnet-4.5-thinking": {
          "name": "Claude 4.5 Sonnet (Thinking)"
        },
        "gpt-5.4-high": {
          "name": "GPT-5.4 High",
          "cost": {
            "input": 2.5,
            "output": 15,
            "cache_read": 0.25,
            "cache_write": 2.5,
            "context_over_200k": {
              "input": 5,
              "output": 22.5,
              "cache_read": 0.5,
              "cache_write": 5
            }
          }
        },
        "gpt-5.4-medium": {
          "name": "GPT-5.4",
          "cost": {
            "input": 2.5,
            "output": 15,
            "cache_read": 0.25,
            "cache_write": 2.5,
            "context_over_200k": {
              "input": 5,
              "output": 22.5,
              "cache_read": 0.5,
              "cache_write": 5
            }
          }
        },
        "gpt-5.3-codex": {
          "name": "GPT-5.3 Codex",
          "cost": {
            "input": 1.75,
            "output": 14,
            "cache_read": 0.175,
            "cache_write": 1.75
          }
        },
        "gpt-5.2": {
          "name": "GPT-5.2",
          "cost": {
            "input": 1.75,
            "output": 14,
            "cache_read": 0.175,
            "cache_write": 1.75
          }
        },
        "gemini-3.1-pro": {
          "name": "Gemini 3.1 Pro",
          "cost": {
            "input": 2,
            "output": 12,
            "cache_read": 0.2,
            "cache_write": 2,
            "context_over_200k": {
              "input": 4,
              "output": 18,
              "cache_read": 0.4,
              "cache_write": 4
            }
          }
        },
        "gemini-3-pro": {
          "name": "Gemini 3 Pro"
        },
        "gemini-3-flash": {
          "name": "Gemini 3 Flash",
          "cost": {
            "input": 0.5,
            "output": 3,
            "cache_read": 0.05,
            "cache_write": 0.5
          }
        },
        "grok": {
          "name": "Grok"
        },
        "kimi-k2.5": {
          "name": "Kimi K2.5",
          "cost": {
            "input": 0.6,
            "output": 3,
            "cache_read": 0.1,
            "cache_write": 0.6
          }
        }
      }
    }
  },

  // General permission
  "permission": {
    "read": {
      "*": "allow",
      "*.env": "deny",
      "*.env.*": "deny",
      "*.env.example": "allow"
    },
    "edit": "allow",
    "bash": {
      "*": "ask",
      "git status*": "allow",
      "git diff*": "allow",
      "grep *": "allow",
      "rg *": "allow",
      "ls *": "allow"
    },
    "grep": "allow",
    "glob": "allow",
    "list": "allow",
    "skill": "allow",
    "todowrite": "allow",
    "todoread": "allow",
    "question": "allow",
    "webfetch": "ask",
    "doom_loop": "ask",
    "external_directory": {
      "*": "ask",
      "~/workspace/odoo/**": "allow"
    }
  },

  "agent": {
    "build": {
      "prompt": "{file:./prompts/build.txt}"
    }
  },

  "command": {
    "test": {
      "template": "Run the full test suite with coverage report and show any failures.\nFocus on the failing tests and suggest fixes.",
      "description": "Run tests with coverage",
      "agent": "build"
    }
  },

  "instructions": ["CONTRIBUTING.md", "docs/guidelines.md", ".cursor/rules/*.md"],

  "formatter": false,

  // Disable noisy directories
  "watcher": {
    "ignore": ["node_modules/**", "dist/**", ".git/**", "__pycache__/**"]
  },

  // Disable shared sessions
  "share": "disabled"
}
