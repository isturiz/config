{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": false,

  "plugin": ["@mohak34/opencode-notifier@latest"],

  // General permission
  "permission": {
    "read": {
      "*": "ask",
      "*.env": "deny",
      "*.env.*": "deny",
      "*.env.example": "allow",
      "./**": "allow",
      "./*": "allow"
    },
    "edit": {
      "*": "ask",
      "./**": "allow",
      "./*": "allow"
    },
    "bash": {
      "*": "ask",
      "git status*": "allow",
      "git diff*": "allow",
      "grep *": "allow",
      "rg *": "allow",
      "ls *": "allow"
    },
    "grep": "allow",
    "glob": "allow",
    "list": "allow",
    "skill": "allow",
    "todowrite": "allow",
    "todoread": "allow",
    "question": "allow",
    "webfetch": "ask",
    "doom_loop": "ask",
    "external_directory": {
      "*": "ask",
      "~/workspace/odoo/**": "allow"
    }
  },

  "mode": {
    "build": {
      "prompt": "{file:./prompts/build.txt}"
    }
  },

  "command": {
    "test": {
      "template": "Run the full test suite with coverage report and show any failures.\nFocus on the failing tests and suggest fixes.",
      "description": "Run tests with coverage",
      "agent": "build"
    }
  },

  "instructions": ["CONTRIBUTING.md", "docs/guidelines.md", ".cursor/rules/*.md"],

  "formatter": false,

  // Disable noisy directories
  "watcher": {
    "ignore": ["node_modules/**", "dist/**", ".git/**", "__pycache__/**"]
  },

  // Disable shared sessions
  "share": "disabled"
}
